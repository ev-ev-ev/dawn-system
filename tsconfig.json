{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM"],
    "allowJs": true,
    "checkJs": false,
    "rootDir": "./src",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@common/*": ["../../Apps/V14/foundry/common/*"],
      "@client/*": ["../../Apps/V14/foundry/client/*"],
      "@setup/*": ["../../Apps/V14/foundry/setup/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
